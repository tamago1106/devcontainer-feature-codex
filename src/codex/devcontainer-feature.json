{
  "id": "codex",
  "version": "0.1.0",
  "name": "OpenAI Codex",
  "description": "Installs the OpenAI Codex VS Code extension and uses the host Codex session inside the dev container.",
  "documentationURL": "https://github.com/tamago1106/devcontainer-feature-codex/tree/main/src/codex",
  "licenseURL": "https://github.com/tamago1106/devcontainer-feature-codex/blob/main/LICENSE",
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ],
  "mounts": [
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.codex",
      "target": "/mnt/codex-host",
      "type": "bind"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "OpenAI.chatgpt"
      ]
    }
  }
}
